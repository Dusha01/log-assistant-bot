# AI
OPEN_AI_KEY=""
OPEN_AI_BASE_URL="https://api.openai.com/v1"
OPEN_AI_MODEL="gpt-4o-mini"
OPEN_AI_TIMEOUT_MS=180000

# Limits
MAX_LOG_LINES_PER_RUN=1000
MAX_LOG_BYTES_PER_RUN=2000000

