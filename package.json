{
  "name": "log-assistant-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/core/cli.ts",
    "analyze:once": "tsx src/core/cli.ts --once",
    "analyze:cron": "tsx src/core/cli.ts --cron",
    "analyze:away": "tsx src/core/cli.ts --away",
    "test": "node --test --import tsx"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1"
  }
}
