####### AI #######
OPEN_AI_KEY="key"
OPEN_AI_BASE_URL="https://api.aitunnel.ru/v1/"
OPEN_AI_MODEL="qwen3.5-9b"

####### Work dir #######
NGINX_LOG_ROOT="/var/log/nginx"
STATE_FILE_PATH=".log-assistant.state.json"
AWAY_STATE_FILE_PATH=".log-assistant-away.state.json"
REPORT_PREFIX="security-report"
CRON_SCHEDULE="0 */2 * * *"
REPORT_RETENTION_DAYS=30
REPORT_CLEANUP_CRON=""
NGINX_LOG_FILE_PATH="/var/log/nginx/access.log"

####### Limit#######
MAX_LOG_LINES_PER_RUN=1000
MAX_LOG_BYTES_PER_RUN=2_000_000